[Unit]
Description=Car2X Data Acquisition Startup (Initialization)
Before=multi-user.target
Wants=systemd-time-wait.service
After=systemd-time-wait.service

[Service]
Type=oneshot
User=car2x
Group=car2x
RuntimeDirectory=car2x
RuntimeDirectoryMode=0755
ExecStartPre=/usr/bin/mkdir -p /run/car2x /home/car2x/captures
ExecStart=/usr/local/bin/car2x-10-startup.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=car2x-startup

[Install]
WantedBy=multi-user.target
